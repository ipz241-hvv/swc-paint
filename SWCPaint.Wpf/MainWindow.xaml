<Window x:Class="SWCPaint.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SWCPaint.Wpf.Views"
        xmlns:vm="clr-namespace:SWCPaint.Wpf.ViewModels"
        xmlns:conv="clr-namespace:SWCPaint.Wpf.Converters"
        xmlns:res="clr-namespace:SWCPaint.Wpf.Resources"
        Title="{x:Static res:Strings.Paint_Window_Title}" Height="720" Width="1280" Icon="/Assets/Icons/paint-icon.png">

    <Window.InputBindings>
        <KeyBinding Key="P" Command="{Binding SelectToolCommand}" CommandParameter="Pencil" />
        <KeyBinding Key="A" Command="{Binding SelectToolCommand}" CommandParameter="Eraser" />
        <KeyBinding Key="R" Command="{Binding SelectToolCommand}" CommandParameter="Rectangle" />
        <KeyBinding Key="E" Command="{Binding SelectToolCommand}" CommandParameter="Ellipse" />
        <KeyBinding Key="L" Command="{Binding SelectToolCommand}" CommandParameter="Line" />

        <KeyBinding Key="Y" Modifiers="Ctrl" Command="{Binding RedoCommand}" />
        <KeyBinding Key="Z" Modifiers="Ctrl" Command="{Binding UndoCommand}" />
        <KeyBinding Key="Y" Modifiers="Ctrl" Command="{Binding RedoCommand}" />
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveProjectCommand}" />
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding NewProjectCommand}" />
    </Window.InputBindings>
    
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="{x:Static res:Strings.Menu_File_Action}">
                <MenuItem Header="{x:Static res:Strings.Menu_NewProject_Action}" Command="{Binding NewProjectCommand}"/>
                <MenuItem Header="{x:Static res:Strings.Menu_SaveProject_Action}" Command="{Binding SaveProjectCommand}"/>
                <MenuItem Header="{x:Static res:Strings.Menu_LoadProject_Action}" Command="{Binding LoadProjectCommand}"/>
                <MenuItem Header="{x:Static res:Strings.Menu_ExportAsImage_Action}" 
                  Command="{Binding ExportImageCommand}" 
                  CommandParameter="{Binding ElementName=MainDrawingCanvas}"/>
                <Separator />
                <MenuItem Header="{x:Static res:Strings.Menu_Exit_Action}" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="{x:Static res:Strings.Menu_Edit_Action}">
                <MenuItem Header="{x:Static res:Strings.Menu_Undo_Action}" Command="{Binding UndoCommand}"/>
                <MenuItem Header="{x:Static res:Strings.Menu_Redo_Action}" Command="{Binding RedoCommand}"/>
            </MenuItem>
        </Menu>

        <views:ToolbarView DockPanel.Dock="Top"/>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" Foreground="#666"/>
            </StatusBarItem>
        </StatusBar>

        <Grid Background="#333">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" 
                          HorizontalScrollBarVisibility="Auto" 
                          VerticalScrollBarVisibility="Auto"
                          Background="Transparent">
                <Border Background="White" 
                        Width="{Binding Project.Width}" 
                        Height="{Binding Project.Height}"
                        Margin="40"
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" Opacity="0.4" ShadowDepth="0"/>
                    </Border.Effect>

                    <views:DrawingCanvas x:Name="MainDrawingCanvas"
                                         Project="{Binding Project}" 
                                         ActiveTool="{Binding CurrentTool}" />
                </Border>
            </ScrollViewer>

            <views:LayersView Grid.Column="1" 
                              DataContext="{Binding LayersContext}" 
                              VerticalAlignment="Stretch"
                              BorderThickness="1,0,0,0"
                              BorderBrush="#ADB5BD"/>
        </Grid>
    </DockPanel>
</Window>