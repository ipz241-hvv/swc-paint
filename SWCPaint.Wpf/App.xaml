<Application x:Class="SWCPaint.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SWCPaint.Wpf"
             xmlns:converters="clr-namespace:SWCPaint.Wpf.Converters"
             xmlns:res="clr-namespace:SWCPaint.Wpf.Resources"
             StartupUri="MainWindow.xaml">

    <Application.Resources>
        <ResourceDictionary>
            <converters:CoreColorToWpfBrushConverter x:Key="CoreColorToWpfBrushConverter" />
            <converters:ToolToBooleanConverter x:Key="ToolToBooleanConverter" />

            <ResourceDictionary.MergedDictionaries>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>